---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
	assertUniqueDiarySlugs,
	formatDateWithSlash,
	formatDiaryDisplayTitle,
	formatWeekday,
	getPostBlocks,
	getPublishedPosts,
	resolveDiarySlug,
	type PublishedPost,
} from "../../lib/notion";
import { renderBlocks } from "../../lib/renderer";

async function renderDiaryContent(post: PublishedPost): Promise<{
	contentHtml: string;
	footnotes: Awaited<ReturnType<typeof renderBlocks>>["footnotes"];
}> {
	const blocks = await getPostBlocks(post.pageId);
	const { html: contentHtml, footnotes } = await renderBlocks(blocks, {
		idPrefix: `diary-index-${post.pageId}-`,
		enhanceJapaneseSpacing: true,
	});

	return { contentHtml, footnotes };
}

function shouldShowDiaryTitle(title: string): boolean {
	const normalized = title.trim();
	if (!normalized) {
		return false;
	}

	return !/^\d{4}[-/.]\d{1,2}[-/.]\d{1,2}(?:\s*\([^)]+\))?$/.test(normalized);
}

const posts = await getPublishedPosts({ type: "Diary" });
assertUniqueDiarySlugs(posts);

const entries = await Promise.all(
	posts.map(async (post) => {
		const slug = resolveDiarySlug(post);
		const { contentHtml, footnotes } = await renderDiaryContent(post);

		return {
			...post,
			slug,
			displayTitle: formatDiaryDisplayTitle(post),
			showTitle: shouldShowDiaryTitle(post.title),
			dateLabel: formatDateWithSlash(post.date)?.replaceAll("/", ".") ?? "",
			weekday: formatWeekday(post.date) ?? "",
			contentHtml,
			footnotes,
		};
	}),
);
---

<BaseLayout title="Diary | frog-blog" headerVariant="narrow">
	<div class="article-grid diary-index-grid">
		{
			entries.length > 0 && (
				<header class="article-header diary-index-header">
					<p class="diary-page-kicker">/Diary</p>
				</header>
			)
		}
		<article class="article-main">
			{
				entries.length === 0 ? (
					<p class="diary-empty">まだ公開された日記はありません。</p>
				) : (
					<section class="diary-list" aria-label="日記一覧">
						{entries.map((entry) => (
							<article class:list={["diary-list-item", !entry.showTitle && "diary-list-item-titleless"]}>
								<a
									class:list={[
										"diary-list-heading-link",
										!entry.showTitle && "diary-list-heading-link-titleless",
									]}
									href={`/diary/${entry.slug}`}
									aria-label={`${entry.displayTitle}の日記を開く`}
								>
									{entry.dateLabel && (
										<div class="diary-list-date">
											<time datetime={entry.date ?? ""}>{entry.dateLabel}</time>
											{entry.weekday && <span>/ {entry.weekday}</span>}
										</div>
									)}
									{entry.showTitle && (
										<h2 class="diary-list-title">{entry.displayTitle}</h2>
									)}
								</a>
								{entry.contentHtml && (
									<div
										class:list={[
											"diary-list-content",
											"article-body",
											!entry.showTitle && "diary-list-content-titleless",
										]}
									>
										<div class="article-content" set:html={entry.contentHtml} />
									</div>
								)}
								{entry.footnotes.length > 0 && (
									<section class="footnotes diary-entry-footnotes" aria-label="脚注">
										<hr />
										<ol>
											{entry.footnotes.map((footnote) => (
												<li id={`fn-${footnote.targetId}`}>
													<span>{footnote.text}</span>{" "}
													<a href={`#fnref-${footnote.targetId}`}>↩</a>
												</li>
											))}
										</ol>
									</section>
								)}
								{entry.tags.length > 0 && (
									<div class="article-tags">
										{entry.tags.map((tag) => (
											<span class="tag-badge">{tag}</span>
										))}
									</div>
								)}
							</article>
						))}
					</section>
				)
			}
		</article>
	</div>
</BaseLayout>
