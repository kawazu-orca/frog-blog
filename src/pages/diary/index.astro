---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
	assertUniqueDiarySlugs,
	formatDiaryDisplayTitle,
	getPostBlocks,
	getPublishedPosts,
	resolveDiarySlug,
	type PublishedPost,
} from "../../lib/notion";
import { extractPlainTextFromBlocks } from "../../lib/renderer";

const weekdayFormatter = new Intl.DateTimeFormat("en", { weekday: "short" });

function parseDiaryDate(post: PublishedPost): Date | null {
	const value = post.date ?? post.title;
	const parsed = new Date(`${value.slice(0, 10)}T00:00:00`);

	return Number.isNaN(parsed.getTime()) ? null : parsed;
}

function formatMonthLabel(date: Date | null): string {
	if (!date) {
		return "日付なし";
	}

	const year = date.getFullYear();
	const month = String(date.getMonth() + 1).padStart(2, "0");
	return `${year}年${month}月`;
}

function formatDateLabel(date: Date | null, fallback: string): string {
	if (!date) {
		return fallback || "日付なし";
	}

	const year = date.getFullYear();
	const month = String(date.getMonth() + 1).padStart(2, "0");
	const day = String(date.getDate()).padStart(2, "0");
	return `${year}/${month}/${day}`;
}

function formatWeekday(date: Date | null): string {
	return date ? weekdayFormatter.format(date) : "";
}

function truncateText(value: string, maxLength: number): string {
	const normalized = value.replace(/\s+/g, " ").trim();
	if (normalized.length <= maxLength) {
		return normalized;
	}

	return `${normalized.slice(0, maxLength).trimEnd()}...`;
}

async function createExcerptSource(post: PublishedPost): Promise<string> {
	if (post.description.trim()) {
		return post.description;
	}

	const blocks = await getPostBlocks(post.pageId);
	return extractPlainTextFromBlocks(blocks);
}

const posts = await getPublishedPosts({ type: "Diary" });
assertUniqueDiarySlugs(posts);

const entries = await Promise.all(
	posts.map(async (post) => {
		const diaryDate = parseDiaryDate(post);
		const slug = resolveDiarySlug(post);
		const excerptSource = await createExcerptSource(post);

		return {
			...post,
			slug,
			displayTitle: formatDiaryDisplayTitle(post),
			dateLabel: formatDateLabel(diaryDate, post.date ?? post.title),
			weekday: formatWeekday(diaryDate),
			monthLabel: formatMonthLabel(diaryDate),
			excerpt: truncateText(excerptSource, 110),
			featuredExcerpt: truncateText(excerptSource, 200),
		};
	}),
);

const [featuredEntry, ...timelineEntries] = entries;

const timelineGroups = timelineEntries.reduce<
	Array<{ monthLabel: string; entries: typeof entries }>
>((groups, entry) => {
	const currentGroup = groups.at(-1);

	if (currentGroup?.monthLabel === entry.monthLabel) {
		currentGroup.entries.push(entry);
		return groups;
	}

	groups.push({ monthLabel: entry.monthLabel, entries: [entry] });
	return groups;
}, []);
---

<BaseLayout title="Diary | frog-blog">
	<section class="page-container diary-index-page">
		<header class="diary-index-hero">
			<h1>Diary</h1>
			<p>日々の短い記録を新しい順に並べています。</p>
			<span>{entries.length} entries</span>
		</header>

		{
			featuredEntry && (
				<a class="diary-featured" href={`/diary/${featuredEntry.slug}`}>
					<div class="diary-featured-meta">
						<time datetime={featuredEntry.date ?? ""}>{featuredEntry.dateLabel}</time>
						{featuredEntry.weekday && <span>({featuredEntry.weekday})</span>}
					</div>
					<h2 class="diary-featured-title">{featuredEntry.displayTitle}</h2>
					{featuredEntry.featuredExcerpt && (
						<p class="diary-featured-excerpt">{featuredEntry.featuredExcerpt}</p>
					)}
					{featuredEntry.tags.length > 0 && (
						<div class="diary-featured-tags" aria-label="タグ">
							{featuredEntry.tags.map((tag) => (
								<span class="tag-badge">{tag}</span>
							))}
						</div>
					)}
				</a>
			)
		}

		{
			entries.length === 0 ? (
				<p class="diary-empty">まだ公開された日記はありません。</p>
			) : timelineEntries.length === 0 ? (
				<p class="diary-empty">タイムラインに表示する過去の日記はまだありません。</p>
			) : (
				<section class="diary-timeline" aria-label="日記タイムライン">
					{timelineGroups.map((group) => (
						<section class="diary-timeline-month" aria-labelledby={`diary-${group.monthLabel}`}>
							<div class="diary-timeline-track">
								<h2 class="diary-timeline-month-label" id={`diary-${group.monthLabel}`}>
									{group.monthLabel}
								</h2>
							</div>
							<div class="diary-timeline-entries">
								{group.entries.map((entry) => (
									<article class="diary-timeline-entry">
										<span class="diary-timeline-dot" aria-hidden="true" />
										<div class="diary-timeline-date">
											<time datetime={entry.date ?? ""}>{entry.dateLabel}</time>
											{entry.weekday && <span>({entry.weekday})</span>}
										</div>
										<div class="diary-timeline-body">
											<h3>
												<a href={`/diary/${entry.slug}`}>{entry.displayTitle}</a>
											</h3>
											{entry.excerpt && <p>{entry.excerpt}</p>}
											{entry.tags.length > 0 && (
												<div class="article-tags">
													{entry.tags.map((tag) => (
														<a class="tag-badge" href={`/tags/${encodeURIComponent(tag)}`}>
															{tag}
														</a>
													))}
												</div>
											)}
										</div>
									</article>
								))}
							</div>
						</section>
					))}
				</section>
			)
		}
	</section>
</BaseLayout>
