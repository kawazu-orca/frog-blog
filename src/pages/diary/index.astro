---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
	assertUniqueDiarySlugs,
	formatDiaryDateLabel,
	formatDiaryDisplayTitle,
	getPostBlocks,
	getPublishedPosts,
	resolveDiarySlug,
	truncateText,
	type PublishedPost,
} from "../../lib/notion";
import { extractPlainTextFromBlocks } from "../../lib/renderer";

async function createExcerptSource(post: PublishedPost): Promise<string> {
	if (post.description.trim()) {
		return post.description;
	}

	const blocks = await getPostBlocks(post.pageId);
	return extractPlainTextFromBlocks(blocks);
}

const posts = await getPublishedPosts({ type: "Diary" });
assertUniqueDiarySlugs(posts);

const entries = await Promise.all(
	posts.map(async (post) => {
		const slug = resolveDiarySlug(post);
		const excerptSource = await createExcerptSource(post);
		const { dateLabel, weekday } = formatDiaryDateLabel(
			post.date ?? post.title,
			post.date ?? post.title,
		);

		return {
			...post,
			slug,
			displayTitle: formatDiaryDisplayTitle(post),
			dateLabel,
			weekday,
			excerpt: truncateText(excerptSource, 110),
		};
	}),
);
---

<BaseLayout title="Diary | frog-blog" headerVariant="narrow">
	<div class="article-grid diary-index-grid">
		<header class="article-header diary-index-header">
			<h1 class="article-title">Diary</h1>
			<div class="article-meta">
				<span>{entries.length} entries</span>
			</div>
		</header>

		<article class="article-main">
			{
				entries.length === 0 ? (
					<p class="diary-empty">まだ公開された日記はありません。</p>
				) : (
					<section class="diary-list" aria-label="日記一覧">
						{entries.map((entry) => (
							<article class="diary-list-item">
								<div class="article-meta diary-list-meta">
									<time datetime={entry.date ?? ""}>{entry.dateLabel}</time>
									{entry.weekday && <span>({entry.weekday})</span>}
								</div>
								<h2 class="diary-list-title">
									<a href={`/diary/${entry.slug}`}>{entry.displayTitle}</a>
								</h2>
								{entry.excerpt && <p class="diary-list-excerpt">{entry.excerpt}</p>}
								{entry.tags.length > 0 && (
									<div class="article-tags">
										{entry.tags.map((tag) => (
											<a class="tag-badge" href={`/articles?tag=${encodeURIComponent(tag)}`}>
												{tag}
											</a>
										))}
									</div>
								)}
							</article>
						))}
					</section>
				)
			}
		</article>
	</div>
</BaseLayout>
