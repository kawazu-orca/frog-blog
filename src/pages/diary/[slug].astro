---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ShareButtons from "../../components/ShareButtons.astro";
import {
	assertUniqueDiarySlugs,
	formatDiaryDateLabel,
	formatDiaryDisplayTitle,
	getPostBlocks,
	getPublishedPosts,
	resolveDiarySlug,
} from "../../lib/notion";
import { renderBlocks } from "../../lib/renderer";

export async function getStaticPaths() {
	const posts = await getPublishedPosts({ type: "Diary" });
	assertUniqueDiarySlugs(posts);

	return posts.map((post) => ({
		params: { slug: resolveDiarySlug(post) },
	}));
}

const slug = Astro.params.slug;
const posts = await getPublishedPosts({ type: "Diary" });
assertUniqueDiarySlugs(posts);

const currentIndex = posts.findIndex((post) => resolveDiarySlug(post) === slug);
const post = currentIndex >= 0 ? posts[currentIndex] : undefined;

if (!post) {
	throw new Error(`Diary not found for slug: ${slug}`);
}

const newerDiary = currentIndex > 0 ? posts[currentIndex - 1] : undefined;
const olderDiary =
	currentIndex >= 0 && currentIndex < posts.length - 1
		? posts[currentIndex + 1]
		: undefined;
const hasBothNavigation = Boolean(newerDiary && olderDiary);
const newerDiaryDate = newerDiary
	? formatDiaryDateLabel(
			newerDiary.date ?? newerDiary.title,
			newerDiary.date ?? newerDiary.title,
		)
	: undefined;
const olderDiaryDate = olderDiary
	? formatDiaryDateLabel(
			olderDiary.date ?? olderDiary.title,
			olderDiary.date ?? olderDiary.title,
		)
	: undefined;

function isDateLikeDiaryTitle(title: string): boolean {
	const normalized = title.trim();
	if (!normalized) {
		return true;
	}

	return /^\d{4}[-/.]\d{1,2}[-/.]\d{1,2}(?:\s*\([^)]+\))?$/.test(
		normalized,
	);
}

const displayTitle = formatDiaryDisplayTitle(post);
const { dateLabel: displayDate, weekday } = formatDiaryDateLabel(
	post.date ?? post.title,
	post.date ?? post.title,
);
const displayDateText = displayDate.replaceAll("/", ".");
const shouldShowTitle = Boolean(
	post.title.trim() &&
		!isDateLikeDiaryTitle(post.title) &&
		post.title.trim() !== displayDate &&
		post.title.trim() !== displayDateText,
);

function shouldShowDiaryNavigationTitle(postTitle: string): boolean {
	return Boolean(postTitle.trim() && !isDateLikeDiaryTitle(postTitle));
}

function formatDiaryNavigationDate(
	date: { dateLabel: string; weekday: string } | undefined,
): { dateLabel: string; weekday: string } | undefined {
	if (!date) {
		return undefined;
	}

	return {
		dateLabel: date.dateLabel.replaceAll("/", "."),
		weekday: date.weekday,
	};
}

const newerDiaryNavigationDate = formatDiaryNavigationDate(newerDiaryDate);
const olderDiaryNavigationDate = formatDiaryNavigationDate(olderDiaryDate);

const blocks = await getPostBlocks(post.pageId);
const { html: contentHtml, footnotes } = await renderBlocks(blocks, {
	idPrefix: `diary-detail-${post.pageId}-`,
	enhanceJapaneseSpacing: true,
});
---

<BaseLayout title={`${displayTitle} | Diary`} headerVariant="diary">
	<div class="article-grid diary-detail-grid">
		<header class="article-header diary-detail-header">
			<a class="diary-page-kicker" href="/diary">/Diary</a>
			<div class="diary-detail-entry">
				<h1 class="article-title diary-detail-date">
					<time datetime={post.date ?? ""}>{displayDateText}</time>
					{weekday && <span>/ {weekday}</span>}
				</h1>
				{shouldShowTitle && <p class="diary-detail-title">{displayTitle}</p>}
				{
					post.tags.length > 0 && (
						<div class="article-tags diary-detail-tags">
							{post.tags.map((tag) => (
								<span class="tag-badge">{tag}</span>
							))}
						</div>
					)
				}
			</div>
		</header>

		<article class="article-main diary-detail-main">
			<div class="article-body">
				<div class="article-content" set:html={contentHtml} />
			</div>

			{
				footnotes.length > 0 && (
					<section class="footnotes diary-entry-footnotes" aria-label="脚注">
						<hr />
						<ol>
							{footnotes.map((footnote) => (
								<li id={`fn-${footnote.targetId}`}>
									<span>{footnote.text}</span>{" "}
									<a href={`#fnref-${footnote.targetId}`}>↩</a>
								</li>
							))}
						</ol>
					</section>
				)
			}

			<footer class="article-end">
				<section class="article-share diary-share" aria-label="日記を共有">
					<ShareButtons title={displayTitle} url={Astro.url.href} showHatena={false} />
				</section>

				<nav
					class={`article-pagination diary-pagination${hasBothNavigation ? " has-both-navigation" : ""}`}
					aria-label="前後の日記"
				>
					{newerDiary && (
						<p class="article-pagination-prev">
							<a
								class="article-pagination-block"
								href={`/diary/${resolveDiarySlug(newerDiary)}`}
								>
									<span class="diary-pagination-arrow" aria-hidden="true">←</span>
									<span class="article-pagination-date">
										{newerDiaryNavigationDate?.dateLabel}
										{newerDiaryNavigationDate?.weekday && (
											<span>{newerDiaryNavigationDate.weekday}</span>
										)}
									</span>
									{shouldShowDiaryNavigationTitle(newerDiary.title) && (
										<span class="article-pagination-title">
											{formatDiaryDisplayTitle(newerDiary)}
										</span>
									)}
								</a>
							</p>
						)}
					{olderDiary && (
						<p class="article-pagination-next">
							<a
								class="article-pagination-block"
								href={`/diary/${resolveDiarySlug(olderDiary)}`}
								>
									<span class="article-pagination-date">
										{olderDiaryNavigationDate?.dateLabel}
										{olderDiaryNavigationDate?.weekday && (
											<span>{olderDiaryNavigationDate.weekday}</span>
										)}
									</span>
									<span class="diary-pagination-arrow" aria-hidden="true">→</span>
									{shouldShowDiaryNavigationTitle(olderDiary.title) && (
										<span class="article-pagination-title">
											{formatDiaryDisplayTitle(olderDiary)}
										</span>
									)}
								</a>
							</p>
						)}
				</nav>

				<p class="article-back"><a href="/diary">日記一覧に戻る</a></p>
			</footer>
		</article>
	</div>
</BaseLayout>
