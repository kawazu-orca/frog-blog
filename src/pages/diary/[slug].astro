---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
	assertUniqueDiarySlugs,
	formatDiaryDateLabel,
	formatDiaryDisplayTitle,
	getPostBlocks,
	getPublishedPosts,
	resolveDiarySlug,
	truncateText,
} from "../../lib/notion";
import { renderBlocks } from "../../lib/renderer";

export async function getStaticPaths() {
	const posts = await getPublishedPosts({ type: "Diary" });
	assertUniqueDiarySlugs(posts);

	return posts.map((post) => ({
		params: { slug: resolveDiarySlug(post) },
	}));
}

const slug = Astro.params.slug;
const posts = await getPublishedPosts({ type: "Diary" });
assertUniqueDiarySlugs(posts);

const currentIndex = posts.findIndex((post) => resolveDiarySlug(post) === slug);
const post = currentIndex >= 0 ? posts[currentIndex] : undefined;

if (!post) {
	throw new Error(`Diary not found for slug: ${slug}`);
}

const newerDiary = currentIndex > 0 ? posts[currentIndex - 1] : undefined;
const olderDiary =
	currentIndex >= 0 && currentIndex < posts.length - 1
		? posts[currentIndex + 1]
		: undefined;
const hasBothNavigation = Boolean(newerDiary && olderDiary);
const newerDiaryDate = newerDiary
	? formatDiaryDateLabel(
			newerDiary.date ?? newerDiary.title,
			newerDiary.date ?? newerDiary.title,
		)
	: undefined;
const olderDiaryDate = olderDiary
	? formatDiaryDateLabel(
			olderDiary.date ?? olderDiary.title,
			olderDiary.date ?? olderDiary.title,
		)
	: undefined;

const displayTitle = formatDiaryDisplayTitle(post);
const { dateLabel: displayDate, weekday } = formatDiaryDateLabel(
	post.date ?? post.title,
	post.date ?? post.title,
);
const blocks = await getPostBlocks(post.pageId);
const { html: contentHtml, footnotes } = await renderBlocks(blocks, {
	idPrefix: `diary-detail-${post.pageId}-`,
});
---

<BaseLayout title={`${displayTitle} | Diary`} headerVariant="narrow">
	<div class="article-grid diary-detail-grid">
		<header class="article-header diary-detail-header">
			<div class="article-meta diary-detail-meta">
				<time datetime={post.date ?? ""}>{displayDate}</time>
				{weekday && <span>({weekday})</span>}
				{
					post.tags.length > 0 && (
						<span class="article-tags">
							{post.tags.map((tag) => (
								<span class="tag-link">{tag}</span>
							))}
						</span>
					)
				}
			</div>
			<h1 class="article-title diary-detail-title">{displayTitle}</h1>
		</header>

		<article class="article-main">
			<div class="article-body">
				<div class="article-content" set:html={contentHtml} />
			</div>

			{
				footnotes.length > 0 && (
					<section class="footnotes diary-entry-footnotes" aria-label="脚注">
						<hr />
						<ol>
							{footnotes.map((footnote) => (
								<li id={`fn-${footnote.targetId}`}>
									<span>{footnote.text}</span>{" "}
									<a href={`#fnref-${footnote.targetId}`}>↩</a>
								</li>
							))}
						</ol>
					</section>
				)
			}

			<footer class="article-end">
				<nav
					class={`article-pagination${hasBothNavigation ? " has-both-navigation" : ""}`}
					aria-label="前後の日記"
				>
					{newerDiary && (
						<p class="article-pagination-prev">
							<a
								class="article-pagination-block"
								href={`/diary/${resolveDiarySlug(newerDiary)}`}
								>
									<span class="article-pagination-label">新しい日記</span>
									<span class="article-pagination-date">
										{newerDiaryDate?.dateLabel}
										{newerDiaryDate?.weekday && <> ({newerDiaryDate.weekday})</>}
									</span>
									<span class="article-pagination-title">
										{formatDiaryDisplayTitle(newerDiary)}
									</span>
									{newerDiary.description && (
										<span class="article-pagination-excerpt">
											{truncateText(newerDiary.description, 110)}
										</span>
									)}
								</a>
							</p>
						)}
					{olderDiary && (
						<p class="article-pagination-next">
							<a
								class="article-pagination-block"
								href={`/diary/${resolveDiarySlug(olderDiary)}`}
								>
									<span class="article-pagination-label">古い日記</span>
									<span class="article-pagination-date">
										{olderDiaryDate?.dateLabel}
										{olderDiaryDate?.weekday && <> ({olderDiaryDate.weekday})</>}
									</span>
									<span class="article-pagination-title">
										{formatDiaryDisplayTitle(olderDiary)}
									</span>
									{olderDiary.description && (
										<span class="article-pagination-excerpt">
											{truncateText(olderDiary.description, 110)}
										</span>
									)}
								</a>
							</p>
						)}
				</nav>

				<p class="article-back"><a href="/diary">日記一覧に戻る</a></p>
			</footer>
		</article>
	</div>
</BaseLayout>
