---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedPosts } from "../../lib/notion";

export async function getStaticPaths() {
	const posts = await getPublishedPosts();
	const tags = [...new Set(posts.flatMap((post) => post.tags ?? []))];

	return tags.map((tag) => ({
		params: { tag },
	}));
}

const tagParam = Astro.params.tag ?? "";
const tag = decodeURIComponent(tagParam);
const posts = (await getPublishedPosts()).filter((post) =>
	(post.tags ?? []).includes(tag),
);
---

<BaseLayout title={`タグ: ${tag}`}>
	<section class="page-container">
		<h1 class="page-title">Tag: {tag}</h1>
		<div class="article-list">
			{
				posts.map((post) => (
					<article class="article-card">
						<a class="article-card-link" href={`/posts/${post.slug}`}>
							<h2 class="article-card-title">{post.title}</h2>
							<div class="article-card-meta">
								<time datetime={post.date ?? ""}>{post.date ?? "日付なし"}</time>
								{
									post.tags?.length > 0 &&
										post.tags.map((postTag) => <span class="tag-badge">{postTag}</span>)
								}
							</div>
							{post.description && (
								<p class="article-card-description">{post.description}</p>
							)}
						</a>
					</article>
				))
			}
		</div>
	</section>
</BaseLayout>
