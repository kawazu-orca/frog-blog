---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedPosts } from "../../lib/notion";

export async function getStaticPaths() {
	const posts = await getPublishedPosts();
	const tags = [...new Set(posts.flatMap((post) => post.tags ?? []))];

	return tags.map((tag) => ({
		params: { tag },
	}));
}

const tagParam = Astro.params.tag ?? "";
const tag = decodeURIComponent(tagParam);
const posts = (await getPublishedPosts()).filter((post) =>
	(post.tags ?? []).includes(tag),
);
---

<BaseLayout title={`タグ: ${tag}`}>
	<section class="page-container list-page">
		<h1 class="page-title">Tag: {tag}</h1>
		<section class="article-list">
			{
				posts.map((post) => (
					<article class="article-list-item">
						<div class="article-meta">
							<div>{post.date ?? "日付なし"}</div>
							{post.series && <div class="series-badge">{post.series}</div>}
						</div>
						<div class="article-body">
							<h2 class="article-title">
								<a href={`/posts/${post.slug}`}>{post.title}</a>
							</h2>
							{post.description && (
								<p class="article-description">{post.description}</p>
							)}
							{post.tags?.length > 0 && (
								<div class="article-tags">
									{post.tags.map((postTag) => (
										<a class="tag-badge" href={`/tags/${encodeURIComponent(postTag)}`}>
											{postTag}
										</a>
									))}
								</div>
							)}
						</div>
						{post.thumbnail && (
							<div class="article-thumbnail">
								<img src={post.thumbnail} alt={post.title} loading="lazy" />
							</div>
						)}
					</article>
				))
			}
		</section>
	</section>
</BaseLayout>
