---
import BaseLayout from "../layouts/BaseLayout.astro";

const sampleTags = ["Math", "Astro", "Notion"];
const sampleCode = 'const f = (x: number) => x * x + 1;';
---

<BaseLayout
	title="Font Preview | frog-blog"
	description="フォント比較プレビュー"
