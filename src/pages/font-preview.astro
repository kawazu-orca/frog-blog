<style>
	@import url("https://fonts.googleapis.com/css2?family=BIZ+UDPGothic:wght@400;700&family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Sans+JP:wght@400;500;700&family=Inter:wght@400;500;600;700&family=M+PLUS+1p:wght@400;500;700&family=M+PLUS+2:wght@400;500;700&family=Noto+Sans+JP:wght@400;500;600;700&family=Shippori+Gothic:wght@400;500;700&family=Zen+Kaku+Gothic+New:wght@400;500;700&display=swap");

	.font-preview-page {
		max-width: 980px;
		padding-top: 3rem;
		padding-bottom: 3rem;
	}

	.preview-header h1 {
		margin-top: 0;
		margin-bottom: 0.5rem;
		font-size: 2rem;
	}

	.preview-header p {
		margin-top: 0;
		margin-bottom: 2rem;
		color: #556275;
	}

	.font-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.preview-subsection {
		margin-top: 2rem;
		margin-bottom: 1rem;
	}

	.preview-subsection h2 {
		margin: 0;
		font-size: 1.1rem;
		color: #334155;
	}

	.preview-subsection p {
		margin: 0.35rem 0 0;
		font-size: 0.9rem;
		color: #5b6a7b;
	}

	.font-card {
		border: 1px solid #d8e1ec;
		border-radius: 10px;
		padding: 1rem;
		background: #f3f7fb;
	}

	.font-name {
		margin: 0 0 0.9rem;
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		color: #607084;
	}

	.sample-title {
		margin: 0;
		font-size: 1.34rem;
		line-height: 1.3;
		font-weight: 700;
		color: #334155;
	}

	.sample-body {
		margin: 0.8rem 0;
		font-size: 1rem;
		line-height: 1.72;
		color: #334155;
	}

	.sample-title-latin {
		margin: 0.35rem 0 0;
		font-size: 1.08rem;
		line-height: 1.45;
		color: #334155;
		font-family: var(--preview-heading-latin) !important;
		font-weight: 600;
	}

	.sample-specimen {
		margin: 0.25rem 0 0.8rem;
		font-size: 0.92rem;
		letter-spacing: 0.01em;
		color: #4b5d72;
		font-family: var(--preview-heading-latin) !important;
	}

	.font-card pre {
		margin: 0;
		padding: 0.75rem;
		border-radius: 6px;
		background: #e8eff7;
		font-size: 0.8rem;
		overflow-x: auto;
	}

	.sample-tags {
		display: flex;
		gap: 0.4rem;
		margin-top: 0.8rem;
	}

	.sample-tags span {
		display: inline-flex;
		align-items: center;
		padding: 0.15rem 0.5rem;
		border-radius: 999px;
		background: #dde7f2;
		font-size: 0.74rem;
		color: #4b5d72;
	}

	.font-inter {
		--preview-heading: "Inter", "Noto Sans JP", "Hiragino Kaku Gothic ProN", sans-serif;
		--preview-heading-latin: "Inter", "Helvetica Neue", Arial, sans-serif;
	}

	.font-manrope {
		--preview-heading: "Manrope", "Noto Sans JP", "Hiragino Kaku Gothic ProN", sans-serif;
		--preview-heading-latin: "Manrope", "Helvetica Neue", Arial, sans-serif;
	}

	.font-ibm {
		--preview-heading: "IBM Plex Sans", "Noto Sans JP", "Hiragino Kaku Gothic ProN", sans-serif;
		--preview-heading-latin: "IBM Plex Sans", "Helvetica Neue", Arial, sans-serif;
	}

	.font-card .sample-title {
		font-family: var(--preview-heading) !important;
	}

	.font-card .sample-body,
	.font-card .sample-tags,
	.font-card .font-name {
		font-family: "Noto Sans JP", "Hiragino Kaku Gothic ProN", "Yu Gothic", sans-serif;
	}

	.font-ja-noto {
