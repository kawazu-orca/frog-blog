---
import ArticleToggleList from "../../components/ArticleToggleList.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedPosts } from "../../lib/notion";

const posts = await getPublishedPosts({ type: "Article" });
---

<BaseLayout title="Articles | frog-blog" headerVariant="narrow">
	<div class="article-grid article-index-grid">
		<article class="article-main">
			{
				posts.length === 0 ? (
					<p class="article-empty article-empty--initial">
						まだ公開された記事はありません。
					</p>
				) : null
			}

			<div class="article-list-heading" aria-hidden="true">
				<span>/Date</span>
				<span>/Title</span>
				<span></span>
			</div>
			<ArticleToggleList posts={posts} label="記事一覧" />
		</article>
	</div>
</BaseLayout>
