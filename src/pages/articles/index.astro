---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedPosts } from "../../lib/notion";

const posts = await getPublishedPosts({ type: "Article" });
---

<BaseLayout title="Articles | frog-blog">
	<section class="page-container list-page">
		<section class="article-list article-list--text">
			{
				posts.map((post) => (
					<article class="article-list-item">
						<div class="article-meta">
							<div>{post.date ?? "日付なし"}</div>
							{post.series && <div class="series-badge">{post.series}</div>}
						</div>
						<div class="article-body">
							<h2 class="article-title">
								<a href={`/posts/${post.slug}`}>{post.title}</a>
							</h2>
							{post.description && (
								<p class="article-description">{post.description}</p>
							)}
							{post.tags?.length > 0 && (
								<div class="article-tags">
									{post.tags.map((tag) => (
										<a class="tag-badge" href={`/tags/${encodeURIComponent(tag)}`}>
											{tag}
										</a>
									))}
								</div>
							)}
						</div>
					</article>
				))
			}
		</section>
	</section>
</BaseLayout>
