---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ShareButtons from "../../components/ShareButtons.astro";
import TableOfContents from "../../components/TableOfContents.astro";
import {
	getPostBlocks,
	getPublishedPosts,
} from "../../lib/notion";
import { extractHeadings, renderBlocks } from "../../lib/renderer";

export async function getStaticPaths() {
	const posts = await getPublishedPosts();
	return posts.map((post) => ({
		params: { slug: post.slug },
	}));
}

const slug = Astro.params.slug;
const posts = await getPublishedPosts();
const currentIndex = posts.findIndex((item) => item.slug === slug);
const post = currentIndex >= 0 ? posts[currentIndex] : undefined;

if (!post) {
	throw new Error(`Post not found for slug: ${slug}`);
}

const previousPost = currentIndex > 0 ? posts[currentIndex - 1] : undefined;
const nextPost =
	currentIndex >= 0 && currentIndex < posts.length - 1
		? posts[currentIndex + 1]
		: undefined;

const blocks = await getPostBlocks(post.pageId);
const headings = extractHeadings(blocks);
const { html: contentHtml, footnotes } = await renderBlocks(blocks);
const displayDate = post.date ?? "日付なし";
const showToC = post.properties.ShowToC === true;
const hasEnoughHeadings = headings.length > 2;
---

<BaseLayout title={post.title}>
	<div class="article-grid">
		<header class="article-header">
			<h1 class="article-title">{post.title}</h1>
			<div class="article-meta">
				<time datetime={post.date ?? ""}>{displayDate}</time>
				{
					post.tags.length > 0 && (
						<span class="article-tags">
							{post.tags.map((tag) => (
								<a class="tag-link" href={`/tags/${encodeURIComponent(tag)}`}>
									{tag}
								</a>
							))}
						</span>
					)
				}
			</div>
		</header>

		{showToC && hasEnoughHeadings && (
			<aside class="toc-sidebar">
				<TableOfContents headings={headings} />
			</aside>
		)}

		<article class="article-main">
			<div class="article-body" style="position: relative;">
				<div class="article-content" set:html={contentHtml} />
				{
					footnotes.length > 0 && (
						<div class="sidenotes-container">
							{footnotes.map((footnote) => (
								<div class="sidenote" id={`fn-${footnote.id}`} role="note">
									<sup>{footnote.id}</sup> {footnote.text}
								</div>
							))}
						</div>
					)
				}
			</div>

			{
				footnotes.length > 0 && (
					<section class="footnotes" aria-label="脚注">
						<hr />
						<ol>
							{footnotes.map((footnote) => (
								<li id={`fn-${footnote.id}-mobile`}>
									<span>{footnote.text}</span>{" "}
									<a href={`#fnref-${footnote.id}`}>↩</a>
								</li>
							))}
						</ol>
					</section>
				)
			}

			<hr />
			<p>この記事をシェアする</p>
			<ShareButtons title={post.title} url={Astro.url.href} />

			<nav>
				{previousPost && (
					<p>
						<a href={`/posts/${previousPost.slug}`}>
							← 前の記事: {previousPost.title}
						</a>
					</p>
				)}
				{nextPost && (
					<p>
						<a href={`/posts/${nextPost.slug}`}>
							次の記事: {nextPost.title} →
						</a>
					</p>
				)}
			</nav>

			<p><a href="/">← 記事一覧に戻る</a></p>
		</article>
	</div>

	<script is:inline>
		const layoutSidenotes = () => {
			const articleBody = document.querySelector(".article-body");
			if (!articleBody) return;

			const container = articleBody.querySelector(".sidenotes-container");
			const content = articleBody.querySelector(".article-content");
			if (!container || !content) return;

			const notes = Array.from(container.querySelectorAll(".sidenote"));
			if (notes.length === 0) return;

			if (window.matchMedia("(max-width: 1199px)").matches) {
				container.style.height = "";
				for (const note of notes) {
					note.style.top = "";
				}
				return;
			}

			const bodyRect = articleBody.getBoundingClientRect();
			let previousBottom = 0;
			const minGap = 12;

			for (const note of notes) {
				const index = note.id.replace("fn-", "");
				const ref = document.getElementById(`fnref-${index}`);
				if (!ref) continue;

				const desiredTop = ref.getBoundingClientRect().top - bodyRect.top;
				const top = Math.max(desiredTop, previousBottom + minGap);
				note.style.top = `${top}px`;
				previousBottom = top + note.offsetHeight;
			}

			container.style.height = `${Math.max(previousBottom, content.scrollHeight)}px`;
		};

		let rafId = 0;
		const requestLayout = () => {
			if (rafId) cancelAnimationFrame(rafId);
			rafId = requestAnimationFrame(layoutSidenotes);
		};

		requestLayout();
		window.addEventListener("load", requestLayout);
		window.addEventListener("resize", requestLayout);
		window.addEventListener("scroll", requestLayout, { passive: true });
		document.addEventListener("astro:page-load", requestLayout);
	</script>
</BaseLayout>
