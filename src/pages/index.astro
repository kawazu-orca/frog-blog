---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPublishedPosts } from "../lib/notion";

const posts = await getPublishedPosts();
---

<BaseLayout title="frog-blog">
	<section class="page-container">
		<h1 class="page-title">Articles</h1>
		<div class="article-list">
			{
				posts.map((post) => (
					<article class="article-card">
						<a class="article-card-link" href={`/posts/${post.slug}`}>
							<h2 class="article-card-title">{post.title}</h2>
							<div class="article-card-meta">
								<time datetime={post.date ?? ""}>{post.date ?? "日付なし"}</time>
								{
									post.tags?.length > 0 &&
										post.tags.map((tag) => <span class="tag-badge">{tag}</span>)
								}
							</div>
							{post.description && (
								<p class="article-card-description">{post.description}</p>
							)}
						</a>
					</article>
				))
			}
		</div>
	</section>
</BaseLayout>
