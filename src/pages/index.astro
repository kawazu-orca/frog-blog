---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
	formatDiaryDisplayTitle,
	getPostBlocks,
	getPublishedPosts,
	resolveDiarySlug,
} from "../lib/notion";
import { renderBlocks } from "../lib/renderer";

const latestArticles = (await getPublishedPosts({ type: "Article" })).slice(0, 3);
const latestDiaryPosts = (await getPublishedPosts({ type: "Diary" })).slice(0, 2);
const latestDiaryEntries = await Promise.all(
	latestDiaryPosts.map(async (post) => {
		const blocks = await getPostBlocks(post.pageId);
		const rendered = await renderBlocks(blocks, {
			idPrefix: `home-diary-${post.pageId}-`,
		});

		return {
			...post,
			diarySlug: resolveDiarySlug(post),
			displayTitle: formatDiaryDisplayTitle(post),
			contentHtml: rendered.html,
			footnotes: rendered.footnotes,
		};
	}),
);
---

<BaseLayout title="frog-blog">
	<section class="page-container home-page">
		<section class="home-hero" aria-labelledby="home-title">
			<h1 id="home-title">frog-blog</h1>
			<p>まとまった記事と、日々の短い記録を置いています。</p>
		</section>

		<section class="home-latest" aria-labelledby="latest-articles-title">
			<div class="home-section-header">
				<h2 id="latest-articles-title">Latest Articles</h2>
				<a href="/articles">All Articles</a>
			</div>
			<section class="article-list article-list--text">
			{
				latestArticles.map((post) => (
					<article class="article-list-item">
						<div class="article-meta">
							<div>{post.date ?? "日付なし"}</div>
							{post.series && <div class="series-badge">{post.series}</div>}
						</div>
						<div class="article-body">
							<h2 class="article-title">
								<a href={`/posts/${post.slug}`}>{post.title}</a>
							</h2>
							{post.description && (
								<p class="article-description">{post.description}</p>
							)}
							{post.tags?.length > 0 && (
								<div class="article-tags">
									{post.tags.map((tag) => (
										<a class="tag-badge" href={`/tags/${encodeURIComponent(tag)}`}>
											{tag}
										</a>
									))}
								</div>
							)}
						</div>
					</article>
				))
			}
			</section>
		</section>

		<section class="home-latest" aria-labelledby="latest-diary-title">
			<div class="home-section-header">
				<h2 id="latest-diary-title">Latest Diary</h2>
				<a href="/diary">All Diary</a>
			</div>
			<section class="diary-timeline home-diary-timeline">
				{
					latestDiaryEntries.map((entry) => (
						<article class="diary-entry article-main" id={`home-${entry.slug}`}>
							<header class="diary-entry-header">
								<div class="article-meta">
									<a class="diary-entry-link" href={`/diary/${entry.diarySlug}`}>
										Permalink
									</a>
								</div>
								<h2 class="diary-entry-title">
									<time datetime={entry.date ?? ""}>{entry.displayTitle}</time>
								</h2>
							</header>
							<div class="article-body">
								<div class="article-content" set:html={entry.contentHtml} />
							</div>
							{entry.footnotes.length > 0 && (
								<section class="footnotes diary-entry-footnotes" aria-label="脚注">
									<hr />
									<ol>
										{entry.footnotes.map((footnote) => (
											<li id={`fn-${footnote.targetId}`}>
												<span>{footnote.text}</span>{" "}
												<a href={`#fnref-${footnote.targetId}`}>↩</a>
											</li>
										))}
									</ol>
								</section>
							)}
						</article>
					))
				}
			</section>
		</section>
	</section>
</BaseLayout>
